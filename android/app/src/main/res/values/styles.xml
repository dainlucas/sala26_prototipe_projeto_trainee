<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Theme aplicado enquanto o processo Android inicia e antes do Flutter desenhar. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
        <item name="android:forceDarkAllowed">false</item>
    </style>

    <!-- Theme aplicado assim que o processo iniciou, atrás da UI Flutter. -->
    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">@color/prototipe_branco</item>
        <item name="android:forceDarkAllowed">false</item>
    </style>
</resources>
